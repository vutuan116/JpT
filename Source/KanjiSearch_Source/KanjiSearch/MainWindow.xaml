<Window x:Class="KanjiSearch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanjiSearch"
        mc:Ignorable="d"
        Title="MainWindow" Height="240" Width="480">
    <StackPanel VerticalAlignment="Center">
        <TextBox Name="txt" Width="380" Margin="16" Height="30" FontSize="14"/>
        <Button Content="Run" Width="120" Height="30" FontSize="16" Click="Button_Run_Click"/>
    </StackPanel>
</Window>
